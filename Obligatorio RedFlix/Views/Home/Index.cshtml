@model List<Obligatorio_RedFlix.Models.Populares>

@if (Session["UsuarioId"] == null)
{
    <section class="hero-redflix">

        <div class="hero-content">

            <h1>
                Películas y series
                <br />
                ilimitadas y mucho más
            </h1>

            <p class="hero-subtitle">
                Comprá o alquilá tus películas favoritas cuando quieras.
            </p>

            <div class="comenzar-box">
                <p>Ingresá tu email para comenzar</p>

                @using (Html.BeginForm("Registrar", "Account", FormMethod.Get, new { @class = "comenzar-form" }))
                {
                    <input type="email"
                           name="email"
                           placeholder="Correo electrónico"
                           class="input-comenzar" />

                    <button type="submit" class="btn-comenzar">
                        Comenzar
                    </button>
                }
            </div>

        </div>

    </section>

    <div class="container pb-5">
        <h2 class="mb-5">Un poco de lo más visto</h2>

        <div class="row">

            @foreach (var pelicula in Model.Take(8))
            {
                <div class="col-md-3 mb-4">
                    <div class="card-redflix">

                        <img src="https://image.tmdb.org/t/p/w500/@pelicula.PosterPath"
                             alt="@pelicula.Title" />

                        <div class="card-body">
                            <h5>@pelicula.Title</h5>
                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
}
else
{
    var destacada = Model.FirstOrDefault();

    <main class="dashboard-redflix">

        @if (destacada != null)
        {
            <section class="dashboard-hero">

                <div class="hero-info">

                    <span class="hero-badge">Destacada</span>

                    <h1>@destacada.Title</h1>

                    <p>
                        Descubrí una de las películas más vistas del momento.
                        Comprala, alquilala o agregala a tu biblioteca.
                    </p>

                    <div class="hero-buttons">
                        <a href="#" class="btn-hero-primary">Ver ahora</a>
                        <a href="#" class="btn-hero-secondary">+ Mi lista</a>
                    </div>

                </div>

                <div class="hero-poster">
                    <img src="https://image.tmdb.org/t/p/w500/@destacada.PosterPath"
                         alt="@destacada.Title" />
                </div>

            </section>
        }

        <section class="dashboard-widgets"
                 style="display:grid; grid-template-columns:repeat(3, 1fr); gap:20px;">

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">CLIMA</span>
                @Html.Action("Widget", "Clima")
            </div>

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">Cotización</span>
                <h3>USD / UYU</h3>
                <p>Próximamente desde API</p>
            </div>

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">Tu cuenta</span>
                <h3>Hola @Session["UsuarioNombre"]</h3>
                <p>Explorá tus películas y series</p>
            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Populares ahora</h2>
                <a href="#">Ver todo</a>
            </div>

            <div class="movie-row-horizontal">

                @foreach (var pelicula in Model.Take(6))
                {
                    <div class="movie-card-wide">

                        <img src="https://image.tmdb.org/t/p/w500/@pelicula.PosterPath"
                             alt="@pelicula.Title" />

                        <div class="movie-card-info">
                            <h3>@pelicula.Title</h3>
                            <p>Película popular</p>
                        </div>

                    </div>
                }

            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Catálogo recomendado</h2>
                <a href="#">Ver todo</a>
            </div>

            <div class="poster-grid-redflix">

                @foreach (var pelicula in Model.Skip(6).Take(12))
                {
                    <div class="poster-card-redflix">

                        <button class="btn-card-plus">+</button>

                        <img src="https://image.tmdb.org/t/p/w500/@pelicula.PosterPath"
                             alt="@pelicula.Title" />

                        <div class="poster-info">
                            <h3>@pelicula.Title</h3>
                            <p>Comprar o alquilar</p>
                        </div>

                    </div>
                }

            </div>

        </section>

    </main>
}
