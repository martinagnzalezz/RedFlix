@model List<Obligatorio_RedFlix.Models.Populares>

@{
    var seriesInicio = ViewBag.Series as System.Collections.Generic.List<Obligatorio_RedFlix.Models.Populares> ?? new System.Collections.Generic.List<Obligatorio_RedFlix.Models.Populares>();
}

@if (Session["UsuarioId"] == null)
{
    <section class="hero-redflix">

        <div class="hero-content">

            <h1>
                Películas y series
                <br />
                ilimitadas y mucho más
            </h1>

            <p class="hero-subtitle">
                Comprá o alquilá tus películas favoritas cuando quieras.
            </p>

            <div class="comenzar-box">
                <p>Ingresá tu email para comenzar</p>

                @using (Html.BeginForm("Registrar", "Account", FormMethod.Get, new { @class = "comenzar-form" }))
                {
                    <input type="email"
                           name="email"
                           placeholder="Correo electrónico"
                           class="input-comenzar" />

                    <button type="submit" class="btn-comenzar">
                        Comenzar
                    </button>
                }
            </div>

        </div>

    </section>

    <div class="container pb-5">
        <h2 class="mb-5">Un poco de lo más visto</h2>

        <div class="row">

            @foreach (var pelicula in Model.Take(8))
            {
                <div class="col-md-3 mb-4">
                    <div class="card-redflix home-card-preview">

                        <img src="@pelicula.ImagenUrl"
                             alt="@pelicula.TituloMostrar" />

                        <div class="card-body">
                            <h5>@pelicula.TituloMostrar</h5>
                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
}
else
{
    var destacada = Model.FirstOrDefault();

    <main class="dashboard-redflix">

        @if (destacada != null)
        {
            <section class="dashboard-hero">

                <div class="hero-info">

                    <span class="hero-badge">Destacada</span>

                    <h1>@destacada.TituloMostrar</h1>

                    <p>
                        Descubrí una de las películas más vistas del momento.
                        Comprala, alquilala o agregala a tu biblioteca.
                    </p>

                    <div class="hero-buttons">
                        <a href="@Url.Action("Detalle", "Pelicula", new { id = destacada.Id })"
                           class="btn-hero-primary">
                            Ver ahora
                        </a>

                        <a href="@Url.Action("AgregarPelicula", "Favoritos", new { idTmdb = destacada.Id, titulo = destacada.TituloMostrar })"
                           class="btn-hero-secondary">
                            + Mi lista
                        </a>
                    </div>

                </div>

                <a class="hero-poster" href="@Url.Action("Detalle", "Pelicula", new { id = destacada.Id })">
                    <img src="@destacada.ImagenUrl"
                         alt="@destacada.TituloMostrar" />
                </a>

            </section>
        }

        <section class="dashboard-widgets"
                 style="display:grid; grid-template-columns:repeat(3, 1fr); gap:20px;">

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">CLIMA</span>
                @Html.Action("Widget", "Clima")
            </div>

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">Cotización</span>
                @Html.Action("Widget", "Cotizacion")
            </div>

            <div class="widget-card"
                 style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; min-height:250px;">
                <span class="widget-label">Tu cuenta</span>
                <h3>Hola @Session["UsuarioNombre"]</h3>
                <p>Explorá tus películas y series</p>
            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Películas populares</h2>
                <a href="@Url.Action("Index", "Pelicula")">Ver todo</a>
            </div>

            <div class="movie-row-horizontal netflix-style-row">

                @foreach (var pelicula in Model.Take(12))
                {
                    <a class="movie-card-wide" href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })">

                        <img src="@(string.IsNullOrEmpty(pelicula.BackdropPath) ? pelicula.ImagenUrl : "https://image.tmdb.org/t/p/w780" + pelicula.BackdropPath)"
                             alt="@pelicula.TituloMostrar" />

                        <div class="movie-card-info">
                            <h3>@pelicula.TituloMostrar</h3>
                            <p>Película popular</p>
                        </div>

                    </a>
                }

            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Series para maratonear</h2>
                <a href="@Url.Action("Series", "Pelicula")">Ver todo</a>
            </div>

            <div class="movie-row-horizontal netflix-style-row">

                @foreach (var serie in seriesInicio.Take(12))
                {
                    <a class="movie-card-wide" href="@Url.Action("DetalleSerie", "Pelicula", new { id = serie.Id })">

                        <img src="@(string.IsNullOrEmpty(serie.BackdropPath) ? serie.ImagenUrl : "https://image.tmdb.org/t/p/w780" + serie.BackdropPath)"
                             alt="@serie.TituloMostrar" />

                        <div class="movie-card-info">
                            <h3>@serie.TituloMostrar</h3>
                            <p>Serie popular</p>
                        </div>

                    </a>
                }

            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Catálogo recomendado</h2>
                <a href="@Url.Action("Index", "Pelicula")">Ver películas</a>
            </div>

            <div class="poster-grid-redflix netflix-style-row">

                @foreach (var pelicula in Model.Skip(6).Take(12))
                {
                    <a class="poster-card-redflix" href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })">

                        <span class="btn-card-plus">+</span>

                        <img src="@(string.IsNullOrEmpty(pelicula.BackdropPath) ? pelicula.ImagenUrl : "https://image.tmdb.org/t/p/w780" + pelicula.BackdropPath)"
                             alt="@pelicula.TituloMostrar" />

                        <div class="poster-info">
                            <h3>@pelicula.TituloMostrar</h3>
                            <p>Comprar o alquilar</p>
                        </div>

                    </a>
                }

            </div>

        </section>

        <section class="content-section">

            <div class="section-header">
                <h2>Más series populares</h2>
                <a href="@Url.Action("Series", "Pelicula")">Ver series</a>
            </div>

            <div class="poster-grid-redflix netflix-style-row">

                @foreach (var serie in seriesInicio.Skip(6).Take(12))
                {
                    <a class="poster-card-redflix" href="@Url.Action("DetalleSerie", "Pelicula", new { id = serie.Id })">

                        <span class="btn-card-plus">+</span>

                        <img src="@(string.IsNullOrEmpty(serie.BackdropPath) ? serie.ImagenUrl : "https://image.tmdb.org/t/p/w780" + serie.BackdropPath)"
                             alt="@serie.TituloMostrar" />

                        <div class="poster-info">
                            <h3>@serie.TituloMostrar</h3>
                            <p>Comprar o alquilar</p>
                        </div>

                    </a>
                }

            </div>

        </section>

    </main>
}
