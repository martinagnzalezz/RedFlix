@model IEnumerable<Obligatorio_RedFlix.Models.PrecioContenido>
@{
    ViewBag.Title = "Gestión de Precios";
}

@section styles {
    <style>
        .admin-page {
            padding: 10px 0 40px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

            .admin-header h2 {
                color: #F0F0F0;
                font-weight: 700;
                margin: 0;
            }

        .btn-gold-sm {
            background: #D4A017;
            color: #000;
            border: none;
            border-radius: 6px;
            padding: 10px 18px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
        }

            .btn-gold-sm:hover {
                background: #F0C040;
                color: #000;
                text-decoration: none;
            }

        .admin-card {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            overflow: hidden;
        }

        .table-redflix {
            margin-bottom: 0;
            color: #F0F0F0;
        }

            .table-redflix thead th {
                background: #1a1a1a;
                color: #888;
                font-size: 12px;
                text-transform: uppercase;
                border-bottom: 1px solid #2a2a2a;
                padding: 14px 20px;
            }

            .table-redflix tbody td {
                padding: 14px 20px;
                border-bottom: 1px solid #1f1f1f;
                vertical-align: middle;
                font-size: 14px;
            }

            .table-redflix tbody tr:hover {
                background: #161616;
            }

        .tipo-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: rgba(212,160,23,0.15);
            color: #D4A017;
            border: 1px solid rgba(212,160,23,0.4);
        }

        .estado-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

            .estado-badge.activo {
                background: rgba(70,211,105,0.12);
                color: #46d369;
                border: 1px solid rgba(70,211,105,0.3);
            }

            .estado-badge.inactivo {
                background: rgba(229,9,20,0.1);
                color: #e50914;
                border: 1px solid rgba(229,9,20,0.3);
            }

        .action-link {
            color: #D4A017;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            margin-right: 12px;
        }

            .action-link:hover {
                color: #F0C040;
                text-decoration: underline;
            }

            .action-link.warn {
                color: #e50914;
            }

        .tmdb-search {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            padding: 22px;
            margin-bottom: 24px;
        }

        .tmdb-search-form {
            display: flex;
            gap: 10px;
        }

            .tmdb-search-form input {
                flex: 1;
                min-width: 0;
                background: #1a1a1a;
                border: 1px solid #333;
                color: #fff;
                border-radius: 7px;
                padding: 11px 14px;
            }

        .tmdb-results {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(180px,1fr));
            gap: 16px;
            margin: 18px 0 26px;
        }

        .tmdb-card {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 10px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

            .tmdb-card img {
                width: 100%;
                aspect-ratio: 2/3;
                object-fit: cover;
                background: #1a1a1a;
            }

        .tmdb-card-body {
            padding: 13px;
            display: flex;
            flex: 1;
            flex-direction: column;
            gap: 8px;
        }

        .tmdb-card h3 {
            font-size: 15px;
            margin: 0;
            color: #fff;
        }

        .tmdb-meta {
            color: #888;
            font-size: 12px;
        }

        .tmdb-card .btn-gold-sm {
            margin-top: auto;
            text-align: center;
        }

        @@media (max-width:600px) {
            .tmdb-search-form {
                flex-direction: column;
            }
        }
    </style>
}

<div class="admin-page">
    <div class="admin-header">
        <h2><i class="fa fa-tags"></i> Gestión de Precios</h2>
        @Html.ActionLink("+ Nuevo precio", "Create", null, new { @class = "btn-gold-sm" })
    </div>

    <div class="tmdb-search">
        <h3 style="margin-top:0;">Buscar contenido</h3>
        <p style="color:#888;">Elegí una película o serie y los datos se completarán automáticamente.</p>
        @using (Html.BeginForm("Index", "Precios", FormMethod.Get, new { @class = "tmdb-search-form" }))
        {
            <input type="search" name="q" value="@ViewBag.Busqueda" placeholder="Ej.: Batman, Stranger Things..." required />
            <button type="submit" class="btn-gold-sm">Buscar</button>
        }
        @if (ViewBag.ErrorTmdb != null)
        {
            <p class="text-danger" style="margin:14px 0 0;">@ViewBag.ErrorTmdb</p>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ViewBag.Busqueda as string))
    {
        var resultados = ViewBag.ResultadosTmdb as List<Obligatorio_RedFlix.Models.Populares>;
        var preciosPorContenido = ViewBag.PreciosPorContenido as Dictionary<string, int>;

        if (resultados != null && resultados.Any())
        {
            <div class="tmdb-results">
                @foreach (var resultado in resultados)
                {
                    string tipo = resultado.MediaType == "tv" ? "serie" : "pelicula";
                    string clave = tipo + ":" + resultado.Id.Value;
                    int idPrecio = 0;
                    bool tienePrecio = preciosPorContenido != null && preciosPorContenido.TryGetValue(clave, out idPrecio);
                    string fecha = resultado.ReleaseDate.HasValue ? resultado.ReleaseDate.Value.Year.ToString()
                        : resultado.FirstAirDate.HasValue ? resultado.FirstAirDate.Value.Year.ToString() : "Sin fecha";

                    <article class="tmdb-card">
                        <img src="@resultado.ImagenUrl" alt="Portada de @resultado.TituloMostrar" />
                        <div class="tmdb-card-body">
                            <h3>@resultado.TituloMostrar</h3>
                            <div class="tmdb-meta">@(tipo == "serie" ? "Serie" : "Película") · @fecha · TMDB #@resultado.Id</div>
                            @if (tienePrecio)
                            {
                                @Html.ActionLink("Editar precio", "Edit", new { id = idPrecio }, new { @class = "btn-gold-sm" })
                            }
                            else
                            {
                                @Html.ActionLink("Asignar precio", "Create", new { tmdbId = resultado.Id.Value, titulo = resultado.TituloMostrar, tipoContenido = tipo }, new { @class = "btn-gold-sm" })
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else if (ViewBag.ErrorTmdb == null)
        {
            <p style="color:#888;">No se encontraron películas o series para esa búsqueda.</p>
        }
    }

    <div class="admin-card">
        <table class="table table-redflix mb-0">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Tipo</th>
                    <th>TMDB ID</th>
                    <th>Compra</th>
                    <th>Alquiler</th>
                    <th>Días</th>
                    <th>Estado</th>
                    <th style="width:180px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Titulo</td>
                        <td><span class="tipo-badge">@item.TipoContenido</span></td>
                        <td>@item.TmdbId</td>
                        <td>USD @item.PrecioCompra.ToString("0.00")</td>
                        <td>USD @item.PrecioAlquier.ToString("0.00")</td>
                        <td>@item.DiasAlquiler</td>
                        <td>
                            <span class="estado-badge @(item.Activo ? "activo" : "inactivo")">
                                @(item.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            @Html.ActionLink("Editar", "Edit", new { id = item.IdPrecio }, new { @class = "action-link" })
                            @Html.ActionLink("Eliminar", "Delete", new { id = item.IdPrecio }, new { @class = "action-link warn" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
