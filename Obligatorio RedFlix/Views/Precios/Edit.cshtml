@model Obligatorio_RedFlix.Models.PrecioContenido

@{
    ViewBag.Title = "Editar Precio";
}

@section styles {
    <style>
        .admin-form-page {
            display: flex;
            justify-content: center;
            padding: 40px 20px;
        }

        .admin-form-box {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            padding: 36px 40px;
            width: 100%;
            max-width: 500px;
        }

            .admin-form-box h2 {
                color: #F0F0F0;
                font-weight: 700;
                margin-bottom: 4px;
                font-size: 22px;
            }

            .admin-form-box hr {
                border-color: #2a2a2a;
                margin-bottom: 24px;
            }

        .rf-input-group {
            margin-bottom: 18px;
        }

            .rf-input-group label {
                display: block;
                font-size: 12px;
                color: #888;
                margin-bottom: 6px;
                font-weight: 500;
                text-transform: uppercase;
            }

            .rf-input-group input,
            .rf-input-group select {
                width: 100%;
                background: #1a1a1a;
                border: 1px solid #2a2a2a;
                border-radius: 8px;
                padding: 12px 14px;
                color: #F0F0F0;
                font-size: 15px;
            }

                .rf-input-group input:focus,
                .rf-input-group select:focus {
                    border-color: #D4A017;
                    outline: none;
                }

        .input-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .btn-gold {
            background: #D4A017;
            color: #000;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
        }

            .btn-gold:hover {
                background: #F0C040;
            }

        .btn-outline-gray {
            background: transparent;
            color: #ccc;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 12px 22px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .text-danger {
            color: #e50914 !important;
            font-size: 13px;
        }

        .hint {
            color: #666;
            font-size: 12px;
            margin-top: 4px;
        }
    </style>
}

<div class="admin-form-page">
    <div class="admin-form-box">
        <h2>Editar precio</h2>
        <hr />

        @using (Html.BeginForm("Edit", "Precios", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            @Html.HiddenFor(model => model.IdPrecio)

            <div class="rf-input-group">
                @Html.LabelFor(model => model.Titulo)
                @Html.EditorFor(model => model.Titulo)
                @Html.ValidationMessageFor(model => model.Titulo, "", new { @class = "text-danger" })
            </div>

            <div class="input-row">
                <div class="rf-input-group">
                    @Html.LabelFor(model => model.TmdbId, "ID de TMDB")
                    @Html.EditorFor(model => model.TmdbId)
                    @Html.ValidationMessageFor(model => model.TmdbId, "", new { @class = "text-danger" })
                    <div class="hint">Lo ves en la URL de la película/serie en TMDB</div>
                </div>

                <div class="rf-input-group">
                    @Html.LabelFor(model => model.TipoContenido, "Tipo")
                    @Html.DropDownListFor(model => model.TipoContenido,
                        new SelectList(new[] { "pelicula", "serie" }, Model.TipoContenido))
                </div>
            </div>

            <div class="input-row">
                <div class="rf-input-group">
                    @Html.LabelFor(model => model.PrecioCompra, "Precio compra (USD)")
                    @Html.EditorFor(model => model.PrecioCompra)
                    @Html.ValidationMessageFor(model => model.PrecioCompra, "", new { @class = "text-danger" })
                </div>

                <div class="rf-input-group">
                    @Html.LabelFor(model => model.PrecioAlquier, "Precio alquiler (USD)")
                    @Html.EditorFor(model => model.PrecioAlquier)
                    @Html.ValidationMessageFor(model => model.PrecioAlquier, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="rf-input-group">
                @Html.LabelFor(model => model.DiasAlquiler, "Días de alquiler")
                @Html.EditorFor(model => model.DiasAlquiler)
                @Html.ValidationMessageFor(model => model.DiasAlquiler, "", new { @class = "text-danger" })
            </div>

            <div class="form-actions">
                <input type="submit" value="Guardar cambios" class="btn-gold" />
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-outline-gray" })
            </div>
        }
    </div>
</div>

