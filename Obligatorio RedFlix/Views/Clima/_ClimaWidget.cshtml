@using Obligatorio_RedFlix.Models
@model ClimaViewModel

@if (Model != null)
{
    <div style="color:white;">

        <div style="display:flex; justify-content:space-between; align-items:flex-start;">

            <div>
                <h3 style="margin:0; color:white;">
                    @Model.Temperatura.ToString("0")°C
                </h3>

                <p style="margin:6px 0 0 0; color:#ccc;">
                    @Model.Ciudad
                </p>

                <p style="margin:4px 0 0 0; color:#aaa; text-transform:capitalize;">
                    @Model.Descripcion
                </p>
            </div>

            <img src="@("https://openweathermap.org/img/wn/" + Model.Icono + "@2x.png")"
                 alt="Clima"
                 style="width:55px; height:55px;" />

        </div>

        <p style="color:#ccc; margin-top:18px; margin-bottom:12px;">
            @Model.Recomendacion
        </p>

        @if (Model.TienePromocionActiva)
        {
            <div style="background:#222; border-left:4px solid #D4AF37; padding:10px; border-radius:6px;">
                <strong style="color:#D4AF37;">Promo:</strong>
                <span style="color:#ddd;">
                    @Model.NombrePromocionActiva - @Model.PorcentajePromocionActiva.ToString("0.##")% OFF
                </span>

                <p style="color:#ccc; margin:6px 0 0 0;">
                    @(string.IsNullOrWhiteSpace(Model.DescripcionPromocionActiva)
                        ? "Promoción aplicada según el clima actual."
                        : Model.DescripcionPromocionActiva)
                </p>
            </div>
        }
        else
        {
            <div style="background:#222; border-left:4px solid #555; padding:10px; border-radius:6px;">
                <strong style="color:#D4AF37;">Promo:</strong>
                <span style="color:#ddd;">No hay promoción activa para este clima.</span>
            </div>
        }

        <a href="@Url.Action("Index", "Clima")"
           style="display:inline-block; margin-top:14px; color:#D4AF37; text-decoration:none;">
            Ver recomendaciones →
        </a>

    </div>
}
else
{
    <p style="color:#ccc;">
        No se pudo cargar el clima.
    </p>
}
