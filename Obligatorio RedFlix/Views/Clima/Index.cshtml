@model Obligatorio_RedFlix.Models.ClimaViewModel
@using System.Linq

@{
    ViewBag.Title = "Clima y recomendaciones";
}

<div class="container-fluid px-5 py-4" style="max-width:1400px;">

    <h2 style="color:#D4AF37; margin-bottom:25px;">
        Clima y recomendaciones
    </h2>

    @if (Model == null)
    {
        <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px;">
            <h3 style="color:#D4AF37;">No se pudo cargar el clima</h3>

            <p style="color:#ccc;">
                Revisá la API Key del clima en el Web.config.
            </p>
        </div>
    }
    else
    {
        <div class="row mb-4">

            <div class="col-md-4 mb-3">
                <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; height:100%;">

                    <span style="color:#D4AF37; font-weight:bold; font-size:13px;">
                        CLIMA ACTUAL
                    </span>

                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:15px;">

                        <div>
                            <h1 style="color:white; margin:0;">
                                @Model.Temperatura.ToString("0")°C
                            </h1>

                            <p style="color:#ccc; margin:8px 0 0 0;">
                                @Model.Ciudad
                            </p>

                            <p style="color:#aaa; margin:5px 0 0 0; text-transform:capitalize;">
                                @Model.Descripcion
                            </p>
                        </div>

                        <img src="@("https://openweathermap.org/img/wn/" + Model.Icono + "@2x.png")"
                             alt="Clima"
                             style="width:80px; height:80px;" />

                    </div>

                    <p style="color:#ccc; margin-top:15px;">
                        Humedad: @Model.Humedad%
                    </p>

                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px; height:100%;">

                    <span style="color:#D4AF37; font-weight:bold; font-size:13px;">
                        RECOMENDACIÓN
                    </span>

                    <h3 style="color:white; margin-top:15px; text-transform:capitalize;">
                        @Model.Emoji @Model.CategoriaClima
                    </h3>

                    <p style="color:#ccc;">
                        @Model.Recomendacion
                    </p>

                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div style="background:#151515; border:1px solid #D4AF37; border-radius:14px; padding:25px; height:100%;">

                    <span style="color:#D4AF37; font-weight:bold; font-size:13px;">
                        PROMOCIÓN ACTIVA
                    </span>

                    <h3 style="color:white; margin-top:15px;">
                        @(Model.TienePromocionActiva ? Model.NombrePromocionActiva : "Sin promoción activa")
                    </h3>

                    @if (Model.TienePromocionActiva)
                    {
                        <p style="color:#ccc; margin-bottom:10px;">
                            @(string.IsNullOrWhiteSpace(Model.DescripcionPromocionActiva)
                                ? "Promoción aplicada según el clima actual."
                                : Model.DescripcionPromocionActiva)
                        </p>

                        <p style="color:#D4AF37; font-weight:bold; font-size:20px; margin-bottom:6px;">
                            @Model.PorcentajePromocionActiva.ToString("0.##")% OFF
                        </p>

                        <p style="color:#aaa; margin:0;">
                            Condición: @Model.CondicionPromocionActiva
                        </p>
                    }
                    else
                    {
                        <p style="color:#ccc;">
                            No hay una promoción creada que coincida con el clima actual.
                        </p>

                        <p style="color:#aaa; margin:0;">
                            Clima actual: @Model.CategoriaClima
                        </p>
                    }

                </div>
            </div>

        </div>

        if (Model.PronosticoDias != null && Model.PronosticoDias.Any())
        {
            <div style="margin-top:35px; margin-bottom:35px;">

                <h3 style="color:#D4AF37; margin-bottom:20px;">
                    Pronóstico de los próximos días
                </h3>

                <div style="display:grid; grid-template-columns:repeat(5, 1fr); gap:22px;">

                    @foreach (var dia in Model.PronosticoDias)
                    {
                        <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:22px; height:100%; text-align:center;">

                            <h5 style="color:#D4AF37; text-transform:capitalize; min-height:45px;">
                                @dia.Dia
                            </h5>

                            <img src="@("https://openweathermap.org/img/wn/" + dia.Icono + "@2x.png")"
                                 alt="Clima"
                                 style="width:75px; height:75px;" />

                            <h3 style="color:white; font-size:32px; margin-top:10px;">
                                @dia.Temperatura.ToString("0")°C
                            </h3>

                            <p style="color:#ccc; text-transform:capitalize; min-height:45px;">
                                @dia.Descripcion
                            </p>

                            <p style="color:#aaa; margin:0;">
                                @dia.Emoji @dia.CategoriaClima
                            </p>

                        </div>
                    }

                </div>

            </div>
        }

        <hr style="border-color:#333;" />

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 style="color:#D4AF37; margin-bottom:5px;">
                    Series recomendadas según el clima
                </h3>

                <p style="color:#aaa; margin:0;">
                    Selección automática de series según el clima actual en @Model.Ciudad.
                </p>
            </div>

            <a href="@Url.Action("Series", "Pelicula")"
               style="color:#D4AF37; text-decoration:none;">
                Ver más series
            </a>
        </div>

        if (Model.SeriesRecomendadas == null || !Model.SeriesRecomendadas.Any())
        {
            <p style="color:#ccc;">
                No se pudieron cargar series recomendadas.
            </p>
        }
        else
        {
            <div class="row">

                @foreach (var serie in Model.SeriesRecomendadas)
                {
                    <div class="col-md-3 mb-4">

                        <div style="background:#151515; border:1px solid #333; border-radius:14px; overflow:hidden; height:100%; position:relative;">

                           

                            <a href="@Url.Action("DetalleSerie", "Pelicula", new { id = serie.Id })"
                               style="text-decoration:none; color:inherit;">

                                <img src="@serie.ImagenUrl"
                                     onerror="this.onerror=null; this.src='https://placehold.co/500x750/151515/D4AF37?text=Sin+imagen';"
                                     style="width:100%; height:330px; object-fit:cover;" />

                                <div style="padding:16px;">

                                    <h5 style="color:white; min-height:55px; margin-bottom:12px;">
                                        @serie.TituloMostrar
                                    </h5>

                                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">

                                        <span style="color:#D4AF37;">
                                            ⭐ @serie.VoteAverage
                                        </span>

                                        <span style="color:#aaa; font-size:13px; text-transform:capitalize;">
                                            @Model.CategoriaClima
                                        </span>

                                    </div>

                                    <p style="color:#aaa; font-size:14px; margin:0;">
                                        Serie recomendada según el clima actual.
                                    </p>

                                </div>

                            </a>

                        </div>

                    </div>
                }

            </div>
        }

        <hr style="border-color:#333;" />

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 style="color:#D4AF37; margin-bottom:5px;">
                    Películas recomendadas según el clima
                </h3>

                <p style="color:#aaa; margin:0;">
                    Selección automática de películas según el clima actual en @Model.Ciudad.
                </p>
            </div>

            <a href="@Url.Action("Index", "Pelicula")"
               style="color:#D4AF37; text-decoration:none;">
                Ver más películas
            </a>
        </div>

        if (Model.PeliculasRecomendadas == null || !Model.PeliculasRecomendadas.Any())
        {
            <p style="color:#ccc;">
                No se pudieron cargar películas recomendadas.
            </p>
        }
        else
        {
            <div class="row">

                @foreach (var pelicula in Model.PeliculasRecomendadas)
                {
                    <div class="col-md-3 mb-4">

                        <div style="background:#151515; border:1px solid #333; border-radius:14px; overflow:hidden; height:100%; position:relative;">

                            

                            <a href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })"
                               style="text-decoration:none; color:inherit;">

                                <img src="@pelicula.ImagenUrl"
                                     onerror="this.onerror=null; this.src='https://placehold.co/500x750/151515/D4AF37?text=Sin+imagen';"
                                     style="width:100%; height:330px; object-fit:cover;" />

                                <div style="padding:16px;">

                                    <h5 style="color:white; min-height:55px; margin-bottom:12px;">
                                        @pelicula.TituloMostrar
                                    </h5>

                                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">

                                        <span style="color:#D4AF37;">
                                            ⭐ @pelicula.VoteAverage
                                        </span>

                                        <span style="color:#aaa; font-size:13px; text-transform:capitalize;">
                                            @Model.CategoriaClima
                                        </span>

                                    </div>

                                    <p style="color:#aaa; font-size:14px; margin:0;">
                                        Película recomendada según el clima actual.
                                    </p>

                                </div>

                            </a>

                        </div>

                    </div>
                }

            </div>
        }
    }

</div>
