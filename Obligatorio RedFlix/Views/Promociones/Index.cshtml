
@model IEnumerable<Obligatorio_RedFlix.Models.PromocionesClima>
@{
    ViewBag.Title = "Promociones por Clima";
}

@section styles {
    <style>
        .admin-page {
            padding: 10px 0 40px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

            .admin-header h2 {
                color: #F0F0F0;
                font-weight: 700;
                margin: 0;
            }

        .btn-gold-sm {
            background: #D4A017;
            color: #000;
            border: none;
            border-radius: 6px;
            padding: 10px 18px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
        }

            .btn-gold-sm:hover {
                background: #F0C040;
                color: #000;
                text-decoration: none;
            }

        .admin-card {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            overflow: hidden;
        }

        .table-redflix {
            margin-bottom: 0;
            color: #F0F0F0;
        }

            .table-redflix thead th {
                background: #1a1a1a;
                color: #888;
                font-size: 12px;
                text-transform: uppercase;
                border-bottom: 1px solid #2a2a2a;
                padding: 14px 20px;
            }

            .table-redflix tbody td {
                padding: 14px 20px;
                border-bottom: 1px solid #1f1f1f;
                vertical-align: middle;
                font-size: 14px;
            }

            .table-redflix tbody tr:hover {
                background: #161616;
            }

        .estado-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: none;
        }

            .estado-badge.activo {
                background: rgba(70,211,105,0.12);
                color: #46d369;
                border: 1px solid rgba(70,211,105,0.3);
            }

            .estado-badge.inactivo {
                background: rgba(229,9,20,0.1);
                color: #e50914;
                border: 1px solid rgba(229,9,20,0.3);
            }

        .action-link {
            color: #D4A017;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            margin-right: 12px;
        }

            .action-link:hover {
                color: #F0C040;
                text-decoration: underline;
            }

            .action-link.warn {
                color: #e50914;
            }

        .desc-badge {
            background: rgba(212,160,23,0.15);
            color: #D4A017;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }
    </style>
}

<div class="admin-page">
    <div class="admin-header">
        <h2><i class="fa fa-cloud-sun-rain"></i> Promociones por Clima</h2>
        @Html.ActionLink("+ Nueva promoción", "Create", null, new { @class = "btn-gold-sm" })
    </div>

    <div class="admin-card">
        <table class="table table-redflix mb-0">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Condición</th>
                    <th>Temp. máx</th>
                    <th>Género</th>
                    <th>Descuento</th>
                    <th>Estado</th>
                    <th style="width:180px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.CondicionClima</td>
                        <td>@(item.TemperaturaMax.HasValue ? item.TemperaturaMax + "°C" : "—")</td>
                        <td>@(item.Genero != null ? item.Genero.Nombre : "Todos")</td>
                        <td><span class="desc-badge">-@item.PorcentajeDesc%</span></td>
                        <td>
                            @using (Html.BeginForm("CambiarEstado", "Promociones", new { id = item.IdPromocion }, FormMethod.Get))
                            {
                                <button type="submit" class="estado-badge @(item.Activa ? "activo" : "inactivo")">
                                    @(item.Activa ? "Activa" : "Inactiva")
                                </button>
                            }
                        </td>
                        <td>
                            @Html.ActionLink("Editar", "Edit", new { id = item.IdPromocion }, new { @class = "action-link" })
                            @Html.ActionLink("Eliminar", "Delete", new { id = item.IdPromocion }, new { @class = "action-link warn" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
