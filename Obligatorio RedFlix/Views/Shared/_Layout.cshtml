<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - RedFlix</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("styles", required: false)
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark redflix-navbar">

        <div class="container-fluid">

            <a class="navbar-brand logo-redflix" href="/">
                REDFLIX
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarRedflix">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarRedflix">


                <ul class="navbar-nav me-auto">

                    @if (Session["UsuarioId"] != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Home")">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index","Pelicula")">
                                Películas
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                Series
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                Favoritos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                Biblioteca
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                Carrito
                            </a>
                        </li>
                    }

                </ul>
                
                <!-- Zona derecha -->
                <div class="d-flex align-items-center">

                    @if (Session["UsuarioId"] == null)
                    {
                        <a href="@Url.Action("Login","Account")"
                           class="btn btn-outline-light me-2">
                            Iniciar sesión
                        </a>

                        <a href="@Url.Action("Registrar","Account")"
                           class="btn btn-gold">
                            Registrarse
                        </a>
                    }
                    else
                    {
                        <input class="form-control me-3"
                               style="width:250px"
                               placeholder="Buscar..." />

                        <span class="text-light me-3">
                            Hola @Session["UsuarioNombre"]
                        </span>

                        <a href="@Url.Action("Logout","Account")"
                           class="btn btn-outline-danger">
                            Salir
                        </a>
                    }

                </div>

            </div>

        </div>

    </nav>

    @RenderBody()

    <div class="container body-content">

        <hr />

        <footer>
            <p>&copy; @DateTime.Now.Year - RedFlix</p>
        </footer>

    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>