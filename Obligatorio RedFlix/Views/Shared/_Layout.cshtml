<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - RedFlix</title>

    @Styles.Render("~/Content/css")
    <link href="@Url.Content("~/Content/site.css")?v=splash4" rel="stylesheet" />

    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("styles", required: false)
</head>

<body class="d-flex flex-column min-vh-100">

    @{
        bool estaLogueado = Session["UsuarioId"] != null;

        bool puedeUsuarios = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Usuarios.Gestionar");
        bool puedeRoles = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Roles.Gestionar");
        bool puedePromociones = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Promociones.Gestionar");
        bool puedeContenido = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Contenido.Gestionar");
        bool puedeReportes = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Reportes.Ver");
        bool puedeCatalogo = estaLogueado && Obligatorio_RedFlix.Helpers.SeguridadHelper.TienePermiso("Catalogo.Usar");
        bool puedeVerPeliculasSeries = puedeCatalogo || puedeContenido || puedeReportes;

        bool puedeAdministracion = puedeUsuarios || puedeRoles || puedePromociones || puedeContenido || puedeReportes;
    }

    @if (ViewContext.RouteData.Values["controller"].ToString() == "Home" &&
         ViewContext.RouteData.Values["action"].ToString() == "Index")
    {
        <div id="splash-logo">
            <div class="splash-content">
                <div class="splash-icon"></div>
                <div class="splash-text">RED<span>FLIX</span></div>
                <p>Cargando experiencia...</p>
            </div>
        </div>
    }

    <nav class="navbar navbar-expand-lg navbar-dark redflix-navbar">

        <div class="container-fluid">

            <a class="navbar-brand logo-redflix" href="@Url.Action("Index", "Home")">
                RED<span>FLIX</span>
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarRedflix">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarRedflix">

                <ul class="navbar-nav me-auto">

                    @if (estaLogueado)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Home")">
                                Inicio
                            </a>
                        </li>

                        if (puedeVerPeliculasSeries)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Pelicula")">
                                    Películas
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Series", "Pelicula")">
                                    Series
                                </a>
                            </li>
                        }

                        if (puedeCatalogo)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Biblioteca")">
                                    Biblioteca
                                </a>
                            </li>
                        }

                        if (puedeAdministracion)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    Administración
                                </a>

                                <ul class="dropdown-menu dropdown-menu-dark">

                                    @if (puedeUsuarios)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Usuarios")">
                                                Usuarios
                                            </a>
                                        </li>
                                    }

                                    @if (puedeRoles)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Roles")">
                                                Roles
                                            </a>
                                        </li>
                                    }

                                    @if (puedePromociones)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Promociones")">
                                                Promociones
                                            </a>
                                        </li>
                                    }

                                    @if (puedeContenido)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Precios")">
                                                Precios / Contenido
                                            </a>
                                        </li>
                                    }

                                    @if (puedeReportes)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Reportes")">
                                                Reportes
                                            </a>
                                        </li>
                                    }

                                </ul>
                            </li>
                        }
                    }

                </ul>

                <div class="d-flex align-items-center">

                    @if (!estaLogueado)
                    {
                        <a href="@Url.Action("Login", "Account")"
                           class="btn btn-outline-light me-2">
                            Iniciar sesión
                        </a>

                        <a href="@Url.Action("Registrar", "Account")"
                           class="btn btn-gold">
                            Registrarse
                        </a>
                    }
                    else
                    {
                        if (puedeVerPeliculasSeries)
                        {
                            using (Html.BeginForm("Buscar", "Pelicula", FormMethod.Get, new { @class = "d-flex me-3" }))
                            {
                                <input class="form-control"
                                       style="width:250px"
                                       name="q"
                                       placeholder="Buscar..."
                                       value="@Request.QueryString["q"]" />
                            }
                        }

                        if (puedeCatalogo)
                        {
                            <a href="@Url.Action("Crear", "Reportes")"
                               class="btn btn-outline-warning me-3">
                                Reportar problema
                            </a>

                            <a href="@Url.Action("Index", "Favoritos")"
                               class="text-light me-3"
                               style="font-size: 26px; text-decoration: none; line-height: 1;"
                               title="Favoritos">
                                ♡
                            </a>

                            <a href="@Url.Action("Index", "Carrito")"
                               class="text-light me-3"
                               style="font-size: 24px; text-decoration: none; line-height: 1;"
                               title="Carrito">
                                🛒
                            </a>
                        }

                        <span class="text-light me-3">
                            Hola @(Session["PerfilNombre"] ?? Session["UsuarioNombre"])
                        </span>

                        if (puedeCatalogo)
                        {
                            <a href="@Url.Action("Seleccionar", "Perfiles")"
                               class="profile-mini me-3"
                               title="Cambiar perfil"
                               style="background:@(Session["PerfilColor"] ?? "#D4AF37");">
                                @(Session["PerfilInicial"] ?? Session["UsuarioNombre"].ToString().Substring(0, 1).ToUpper())
                            </a>
                        }

                        <a href="@Url.Action("Logout","Account")"
                           class="btn btn-outline-danger">
                            Salir
                        </a>
                    }

                </div>

            </div>

        </div>

    </nav>

    <main class="container-fluid px-5 body-content flex-grow-1">
        @RenderBody()
    </main>

    <footer class="container-fluid px-5 mt-5 pt-4 pb-4"
            style="border-top:1px solid #333;">
        <p class="mb-0">&copy; @DateTime.Now.Year - RedFlix</p>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)

</body>
</html> 