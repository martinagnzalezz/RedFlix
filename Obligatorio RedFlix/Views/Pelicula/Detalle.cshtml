@model Obligatorio_RedFlix.Models.PeliculaDetalleViewModel

@{
    ViewBag.Title = Model.Pelicula.Title;
}

<div class="redflix-page">
    <div class="row">
        <div class="col-md-4">
            <img src="@Model.Pelicula.ImagenUrl" style="width:100%; border-radius:12px;" />
        </div>

        <div class="col-md-8">
            <h2 class="redflix-title">@Model.Pelicula.Title</h2>

            <p><strong>ID TMDB:</strong> @Model.Pelicula.Id</p>
            <p><strong>Fecha de estreno:</strong> @Model.Pelicula.ReleaseDate</p>
            <p><strong>Puntaje:</strong> ⭐ @Model.Pelicula.VoteAverage</p>

            <p style="color:#ccc;">
                @Model.Pelicula.Overview
            </p>
        </div>
    </div>

    <hr />

    <h3 class="redflix-title">Tráiler</h3>

    @if (Model.Trailer != null)
    {
        <div class="embed-responsive embed-responsive-16by9">
            <iframe width="100%" height="450"
                    src="@Model.Trailer.YoutubeUrl"
                    frameborder="0"
                    allowfullscreen>
            </iframe>
        </div>
    }
    else
    {
        <p>No hay tráiler disponible para esta película.</p>
    }
</div>