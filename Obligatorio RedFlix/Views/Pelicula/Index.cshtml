@model List<Obligatorio_RedFlix.Models.Populares>

@{
    ViewBag.Title = "Películas";

    int paginaActual = ViewBag.PaginaActual != null ? Convert.ToInt32(ViewBag.PaginaActual) : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? Convert.ToInt32(ViewBag.TotalPaginas) : 1;

    int paginaMenosDiez = Math.Max(1, paginaActual - 10);
    int paginaMasDiez = Math.Min(totalPaginas, paginaActual + 10);

    int paginaInicio = Math.Max(1, paginaActual - 2);
    int paginaFin = Math.Min(totalPaginas, paginaActual + 2);
}

<div class="container-fluid px-5 py-4" style="max-width:1600px;">

    <h2 class="mb-4" style="color:#D4AF37;">Películas</h2>

    <div class="row">

        @foreach (var pelicula in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card card-redflix" style="height:100%;">

                    <a href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })">
                        <img src="@pelicula.ImagenUrl"
                             class="card-img-top"
                             style="height:300px; object-fit:cover;" />
                    </a>

                    <div class="card-body">

                        <a href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })"
                           style="text-decoration:none; color:inherit;">
                            <h5 style="min-height:45px;">
                                @pelicula.Title
                            </h5>
                        </a>

                        <p style="color:#ccc;">
                            ⭐ @pelicula.VoteAverage
                        </p>

                        <p style="font-size:13px; color:#aaa; min-height:60px;">
                            @(pelicula.Overview != null && pelicula.Overview.Length > 100
                                ? pelicula.Overview.Substring(0, 100) + "..."
                                : pelicula.Overview)
                        </p>

                      

                    </div>

                </div>
            </div>
        }

    </div>

    <div class="mt-4 text-center">

        @Html.ActionLink(
            "Inicio",
            "Index",
            "Pelicula",
            new { pagina = 1 },
            new { @class = "btn btn-secondary", style = "margin:4px;" }
        )

        @if (paginaActual > 1)
        {
            @Html.ActionLink(
                "Anterior",
                "Index",
                "Pelicula",
                new { pagina = paginaActual - 1 },
                new { @class = "btn btn-secondary", style = "margin:4px;" }
            )
        }

        @if (paginaActual > 10)
        {
            @Html.ActionLink(
                "-10",
                "Index",
                "Pelicula",
                new { pagina = paginaMenosDiez },
                new { @class = "btn btn-secondary", style = "margin:4px;" }
            )
        }

        @for (int i = paginaInicio; i <= paginaFin; i++)
        {
            if (i == paginaActual)
            {
                <span class="btn btn-gold" style="margin:4px;">@i</span>
            }
            else
            {
                @Html.ActionLink(
                    i.ToString(),
                    "Index",
                    "Pelicula",
                    new { pagina = i },
                    new { @class = "btn btn-outline-light", style = "margin:4px;" }
                )
            }
        }

        @if (paginaActual + 10 <= totalPaginas)
        {
            @Html.ActionLink(
                "+10",
                "Index",
                "Pelicula",
                new { pagina = paginaMasDiez },
                new { @class = "btn btn-secondary", style = "margin:4px;" }
            )
        }

        @if (paginaActual < totalPaginas)
        {
            @Html.ActionLink(
                "Siguiente",
                "Index",
                "Pelicula",
                new { pagina = paginaActual + 1 },
                new { @class = "btn btn-gold", style = "margin:4px;" }
            )
        }

    </div>

    <div class="mt-3 text-center">

        <span style="color:#ccc;">
            Página @paginaActual de @totalPaginas
        </span>

        @using (Html.BeginForm("Index", "Pelicula", FormMethod.Get))
        {
            <input type="number"
                   name="pagina"
                   min="1"
                   max="@totalPaginas"
                   value="@paginaActual"
                   class="form-control d-inline-block"
                   style="width:100px; display:inline-block; margin-left:10px;" />

            <button type="submit" class="btn btn-gold">
                Ir
            </button>
        }

    </div>

</div>