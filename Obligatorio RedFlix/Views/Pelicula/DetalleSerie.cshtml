@model Obligatorio_RedFlix.Models.PeliculaDetalleViewModel

@{
    ViewBag.Title = Model.Pelicula != null ? Model.Pelicula.TituloMostrar : "Detalle de serie";
}

<div class="container-fluid px-5 py-4" style="max-width:1400px;">

    @if (Model.Pelicula == null)
    {
        <h2 style="color:#D4AF37;">No se encontró la serie</h2>
        <p style="color:#ccc;">No se pudo cargar la información desde TMDB.</p>
    }
    else
    {
        <div class="row">

            <div class="col-md-4">
                <img src="@Model.Pelicula.ImagenUrl"
                     style="width:100%; border-radius:12px;" />
            </div>

            <div class="col-md-8">

                <div style="display:flex; align-items:center; justify-content:space-between; gap:15px;">

                    <h2 style="color:#D4AF37; margin:0;">
                        @Model.Pelicula.TituloMostrar
                    </h2>

                    @if (Session["UsuarioId"] != null)
                    {
                        <a href="@Url.Action("AgregarSerie", "Favoritos", new { idTmdb = Model.Pelicula.Id, titulo = Model.Pelicula.TituloMostrar })"
                           style="font-size:34px; color:white; text-decoration:none; line-height:1;"
                           title="Agregar a favoritos">
                            ♡
                        </a>
                    }

                </div>

                <p style="color:#ccc; margin-top:20px;">
                    <strong>ID TMDB:</strong> @Model.Pelicula.Id
                </p>

                <p style="color:#ccc;">
                    <strong>Fecha de estreno:</strong> @Model.Pelicula.FechaMostrar
                </p>

                <p style="color:#ccc;">
                    <strong>Puntaje:</strong> ⭐ @Model.Pelicula.VoteAverage
                </p>

                <p style="color:#aaa;">
                    @Model.Pelicula.Overview
                </p>

                @Html.Action("PrecioContenido", "Cotizacion", new { tipoContenido = "Serie", idTmdb = Model.Pelicula.Id, titulo = Model.Pelicula.TituloMostrar })

            </div>

        </div>

        <hr style="border-color:#333;" />

        if (Model.Actores != null && Model.Actores.Count > 0)
        {
            <h3 style="color:#D4AF37; margin-top:30px;">Reparto principal</h3>

            <div class="row">
                @foreach (var actor in Model.Actores)
                {
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("Actor", "Pelicula", new { id = actor.Id })"
                           style="display:block; background:#151515; border:1px solid #333; border-radius:12px; padding:12px; color:inherit; text-decoration:none; height:100%;">
                            <img src="@actor.FotoUrl"
                                 style="width:100%; height:220px; object-fit:cover; border-radius:8px;" />

                            <h5 style="color:white; margin-top:10px;">
                                @actor.Nombre
                            </h5>

                            <p style="color:#aaa; margin:0;">
                                @actor.Personaje
                            </p>
                        </a>
                    </div>
                }
            </div>

            <hr style="border-color:#333;" />
        }

        <h3 style="color:#D4AF37;">Tráiler</h3>

        if (Model.Trailer != null)
        {
            <iframe width="100%"
                    height="450"
                    src="@Model.Trailer.YoutubeUrl"
                    frameborder="0"
                    allowfullscreen>
            </iframe>
        }
        else
        {
            <p style="color:#ccc;">
                No hay tráiler disponible para esta serie.
            </p>
        }
    }

</div>
