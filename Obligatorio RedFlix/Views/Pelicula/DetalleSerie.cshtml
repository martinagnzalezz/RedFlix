@model Obligatorio_RedFlix.Models.PeliculaDetalleViewModel
@using Obligatorio_RedFlix.Models
@using System.Collections.Generic

@{
    ViewBag.Title = Model.Pelicula != null ? Model.Pelicula.TituloMostrar : "Detalle de serie";
}

<div class="container-fluid px-5 py-4" style="max-width:1400px;">

    @if (TempData["MensajeCarrito"] != null)
    {
        <div class="alert alert-warning">
            @TempData["MensajeCarrito"]
        </div>
    }

    @if (TempData["MensajeFavorito"] != null)
    {
        <div class="alert alert-info">
            @TempData["MensajeFavorito"]
        </div>
    }

    @if (TempData["MensajeBiblioteca"] != null)
    {
        <div class="alert alert-info">
            @TempData["MensajeBiblioteca"]
        </div>
    }

    @if (Model.Pelicula == null)
    {
        <h2 style="color:#D4AF37;">No se encontró la serie</h2>
        <p style="color:#ccc;">No se pudo cargar la información desde TMDB.</p>
    }
    else
    {
        <div class="row">

            <div class="col-md-4">
                <img src="@Model.Pelicula.ImagenUrl"
                     onerror="this.onerror=null; this.src='https://placehold.co/500x750/151515/D4AF37?text=Sin+imagen';"
                     style="width:100%; border-radius:12px;" />
            </div>

            <div class="col-md-8">

                <div style="display:flex; align-items:center; justify-content:space-between; gap:15px;">

                    <h2 style="color:#D4AF37; margin:0;">
                        @Model.Pelicula.TituloMostrar
                    </h2>

                    @if (Session["UsuarioId"] != null)
                    {
                        bool estaEnFavoritos = ViewBag.EstaEnFavoritos != null && ViewBag.EstaEnFavoritos == true;

                        <div style="display:flex; align-items:center; gap:18px;">

                            <a href="@Url.Action("AgregarSerie", "Favoritos", new { idTmdb = Model.Pelicula.Id, titulo = Model.Pelicula.TituloMostrar })"
                               style="font-size:36px; color:white; text-decoration:none; line-height:1; text-shadow:0 0 10px rgba(255,255,255,0.7);"
                               title="@(estaEnFavoritos ? "Ya está en favoritos" : "Agregar a favoritos")">
                                @(estaEnFavoritos ? "♥" : "♡")
                            </a>

                            <button type="button"
                                    onclick="togglePanelLista()"
                                    title="Guardar en lista"
                                    style="background:none; border:none; padding:0; cursor:pointer; display:flex; align-items:center;">

                                <svg viewBox="0 0 24 24" width="30" height="30">
                                    <path d="M6 3h12a1 1 0 0 1 1 1v17l-7-5-7 5V4a1 1 0 0 1 1-1z"
                                          fill="none"
                                          stroke="white"
                                          stroke-width="1.8" />
                                </svg>

                            </button>

                        </div>
                    }

                </div>

                @if (Session["UsuarioId"] != null)
                {
                    var listasUsuario = ViewBag.ListasUsuario as List<ListasPersonalizada>;

                    <div id="panelGuardarLista"
                         style="display:none; background:#151515; border:1px solid #333; border-radius:14px; padding:18px; margin-top:18px;">

                        <h5 style="color:#D4AF37; margin-bottom:14px;">
                            Guardar en lista
                        </h5>

                        @if (listasUsuario == null || !listasUsuario.Any())
                        {
                            <p style="color:#ccc;">
                                Todavía no tenés listas creadas.
                            </p>

                            <a href="@Url.Action("Crear", "Biblioteca")" class="btn btn-gold">
                                Crear lista
                            </a>
                        }
                        else
                        {
                            using (Html.BeginForm("AgregarContenido", "Biblioteca", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="idTmdb" value="@Model.Pelicula.Id" />
                                <input type="hidden" name="titulo" value="@Model.Pelicula.TituloMostrar" />
                                <input type="hidden" name="tipoContenido" value="Serie" />

                                <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">

                                    <select name="idLista"
                                            class="form-control"
                                            style="background:#111; color:white; border:1px solid #333; max-width:420px; height:42px;">
                                        @foreach (var lista in listasUsuario)
                                        {
                                            <option value="@lista.IdLista">@lista.Nombre</option>
                                        }
                                    </select>

                                    <button type="submit"
                                            class="btn btn-gold"
                                            style="height:42px; padding:0 25px;">
                                        Agregar
                                    </button>

                                </div>
                            }
                        }

                    </div>
                }

                <p style="color:#ccc; margin-top:20px;">
                    <strong>ID TMDB:</strong> @Model.Pelicula.Id
                </p>

                <p style="color:#ccc;">
                    <strong>Fecha de estreno:</strong> @Model.Pelicula.FechaMostrar
                </p>

                <p style="color:#ccc;">
                    <strong>Puntaje:</strong> ⭐ @Model.Pelicula.VoteAverage
                </p>

                <p style="color:#aaa;">
                    @Model.Pelicula.Overview
                </p>

                @Html.Action("PrecioContenido", "Cotizacion", new { tipoContenido = "Serie", idTmdb = Model.Pelicula.Id, titulo = Model.Pelicula.TituloMostrar })

            </div>

        </div>

        <hr style="border-color:#333;" />

        if (Model.Actores != null && Model.Actores.Count > 0)
        {
            <h3 style="color:#D4AF37; margin-top:30px;">Reparto principal</h3>

            <div class="row">
                @foreach (var actor in Model.Actores)
                {
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("Actor", "Pelicula", new { id = actor.Id })"
                           style="display:block; background:#151515; border:1px solid #333; border-radius:12px; padding:12px; color:inherit; text-decoration:none; height:100%;">
                            <img src="@actor.FotoUrl"
                                 style="width:100%; height:220px; object-fit:cover; border-radius:8px;" />

                            <h5 style="color:white; margin-top:10px;">
                                @actor.Nombre
                            </h5>

                            <p style="color:#aaa; margin:0;">
                                @actor.Personaje
                            </p>
                        </a>
                    </div>
                }
            </div>

            <hr style="border-color:#333;" />
        }

        <h3 style="color:#D4AF37;">Tráiler</h3>

        if (Model.Trailer != null)
        {
            <iframe width="100%"
                    height="450"
                    src="@Model.Trailer.YoutubeUrl"
                    frameborder="0"
                    allowfullscreen>
            </iframe>
        }
        else
        {
            <p style="color:#ccc;">
                No hay tráiler disponible para esta serie.
            </p>
        }
    }

</div>

<script>
    function togglePanelLista() {
        var panel = document.getElementById("panelGuardarLista");

        if (!panel) {
            return;
        }

        if (panel.style.display === "none" || panel.style.display === "") {
            panel.style.display = "block";
        } else {
            panel.style.display = "none";
        }
    }
</script>