
@model Obligatorio_RedFlix.Models.BusquedaViewModel

@{
    ViewBag.Title = "Buscar";
}

<div class="container-fluid px-5 py-4" style="max-width:1600px;">
    <h2 style="color:#D4AF37; margin-bottom:8px;">Buscar</h2>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <p style="color:#ccc;">Escribí algo en el buscador para encontrar películas y series.</p>
    }
    else
    {
        <p style="color:#ccc; margin-bottom:30px;">
            Resultados para: <strong>@Model.Query</strong>
        </p>

        <section class="content-section">
            <div class="section-header">
                <h2>Actores</h2>
            </div>

            @if (Model.Actores.Count == 0)
            {
                <p style="color:#aaa;">No encontramos actores con ese texto.</p>
            }
            else
            {
                <div class="row">
                    @foreach (var actor in Model.Actores)
                    {
                        <div class="col-md-2 mb-4">
                            <a href="@Url.Action("Actor", "Pelicula", new { id = actor.Id })"
                               style="display:block; background:#151515; border:1px solid #333; border-radius:12px; padding:12px; color:inherit; text-decoration:none; height:100%;">
                                <img src="@actor.FotoUrl"
                                     alt="@actor.Nombre"
                                     style="width:100%; height:210px; object-fit:cover; border-radius:8px;" />
                                <h5 style="color:white; margin-top:10px; font-size:15px;">
                                    @actor.Nombre
                                </h5>
                            </a>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="content-section">
            <div class="section-header">
                <h2>Películas</h2>
            </div>

            @if (Model.Peliculas.Count == 0)
            {
                <p style="color:#aaa;">No encontramos películas con ese texto.</p>
            }
            else
            {
                <div class="poster-grid-redflix netflix-style-row">
                    @foreach (var pelicula in Model.Peliculas)
                    {
                        <a class="poster-card-redflix" href="@Url.Action("Detalle", "Pelicula", new { id = pelicula.Id })">
                            <img src="@(string.IsNullOrEmpty(pelicula.BackdropPath) ? pelicula.ImagenUrl : "https://image.tmdb.org/t/p/w780" + pelicula.BackdropPath)"
                                 alt="@pelicula.TituloMostrar" />
                            <div class="poster-info">
                                <h3>@pelicula.TituloMostrar</h3>
                                <p>Película</p>
                            </div>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="content-section">
            <div class="section-header">
                <h2>Series</h2>
            </div>

            @if (Model.Series.Count == 0)
            {
                <p style="color:#aaa;">No encontramos series con ese texto.</p>
            }
            else
            {
                <div class="poster-grid-redflix netflix-style-row">
                    @foreach (var serie in Model.Series)
                    {
                        <a class="poster-card-redflix" href="@Url.Action("DetalleSerie", "Pelicula", new { id = serie.Id })">
                            <img src="@(string.IsNullOrEmpty(serie.BackdropPath) ? serie.ImagenUrl : "https://image.tmdb.org/t/p/w780" + serie.BackdropPath)"
                                 alt="@serie.TituloMostrar" />
                            <div class="poster-info">
                                <h3>@serie.TituloMostrar</h3>
                                <p>Serie</p>
                            </div>
                        </a>
                    }
                </div>
            }
        </section>
    }
</div>