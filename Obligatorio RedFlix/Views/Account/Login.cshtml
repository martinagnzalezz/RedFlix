@{
    ViewBag.Title = "Iniciar sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
      
        .rf-sidebar {
            display: none !important;
        }

        .rf-main {
            margin-left: 0 !important;
        }

        .rf-footer {
            margin-left: 0 !important;
            display: none !important;
        }

        .login-page {
            min-height: calc(100vh - 64px);
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75));
            padding: 40px 20px;
        }

        .login-box {
            background: rgba(10,10,10,0.95);
            border: 1px solid #2a2a2a;
            border-radius: 16px;
            padding: 48px 52px;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.8);
        }

        .login-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 32px;
            justify-content: center;
        }

            .login-logo i {
                color: #D4A017;
                font-size: 24px;
            }

            .login-logo span {
                color: #D4A017;
                font-size: 26px;
                font-weight: 900;
                letter-spacing: 1px;
            }

        .login-box h2 {
            font-size: 24px;
            font-weight: 700;
            color: #F0F0F0;
            margin-bottom: 6px;
            text-align: center;
        }

        .login-box p.subtitle {
            color: #888;
            font-size: 14px;
            text-align: center;
            margin-bottom: 28px;
        }

        .rf-input-group {
            margin-bottom: 16px;
            position: relative;
        }

            .rf-input-group label {
                display: block;
                font-size: 12px;
                color: #888;
                margin-bottom: 6px;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .rf-input-group .input-wrap {
                position: relative;
            }

                .rf-input-group .input-wrap i {
                    position: absolute;
                    left: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #555;
                    font-size: 14px;
                }

            .rf-input-group input {
                width: 100%;
                background: #1a1a1a;
                border: 1px solid #2a2a2a;
                border-radius: 8px;
                padding: 13px 14px 13px 40px;
                color: #F0F0F0;
                font-size: 15px;
                outline: none;
                transition: border 0.2s;
            }

                .rf-input-group input:focus {
                    border-color: #D4A017;
                }

                .rf-input-group input::placeholder {
                    color: #555;
                }

        .btn-login {
            width: 100%;
            background: #D4A017;
            color: #000;
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: background 0.2s;
            letter-spacing: 0.5px;
        }

            .btn-login:hover {
                background: #F0C040;
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
        }

            .divider hr {
                flex: 1;
                border-color: #2a2a2a;
            }

            .divider span {
                color: #555;
                font-size: 12px;
            }

        .login-footer {
            text-align: center;
            margin-top: 20px;
            color: #888;
            font-size: 14px;
        }

            .login-footer a {
                color: #D4A017;
                text-decoration: none;
                font-weight: 600;
            }

                .login-footer a:hover {
                    color: #F0C040;
                    text-decoration: underline;
                }

        .error-box {
            background: rgba(229,9,20,0.1);
            border: 1px solid rgba(229,9,20,0.3);
            border-radius: 8px;
            padding: 12px 16px;
            color: #e50914;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        
    </style>
}

<div class="login-page">
    <div class="login-box">

        <!-- Logo -->
        <div class="login-logo">
            <i class="fa fa-star"></i>
            <span>REDFLIX</span>
        </div>

        <h2>Bienvenido</h2>
        <p class="subtitle">Ingresá a tu cuenta para continuar</p>

        <!-- Error -->
        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                <i class="fa fa-exclamation-circle"></i>
                @ViewBag.Error
            </div>
        }


        <!-- Formulario -->
        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="rf-input-group">
                <label>Email</label>
                <div class="input-wrap">
                    <i class="fa fa-envelope"></i>
                    <input type="email" name="email" id="emailInput" placeholder="tu@email.com" required />
                </div>
            </div>

            <div class="rf-input-group">
                <label>Contraseña</label>
                <div class="input-wrap">
                    <i class="fa fa-lock"></i>
                    <input type="password" name="password" id="passwordInput" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fa fa-sign-in-alt"></i> Iniciar sesión
            </button>
        }

        <div class="login-footer">
            ¿No tenés cuenta?
            <a href="@Url.Action("Registrar", "Account")">Registrate gratis</a>
        </div>
    </div>
</div>

@section scripts {
    <script>function fillLogin(email, password) {
        document.getElementById('emailInput').value = email;
        document.getElementById('passwordInput').value = password;
    }</script>
}
