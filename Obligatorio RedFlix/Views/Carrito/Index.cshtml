@model List<Obligatorio_RedFlix.Models.CarritoItemVistaViewModel>
@using System.Linq

@{
    ViewBag.Title = "Mi carrito";
}

<div class="container-fluid px-5 py-4" style="max-width:1400px;">

    <h2 style="color:#D4AF37; margin-bottom:25px;">
        Mi carrito
    </h2>

    @if (TempData["MensajeCarrito"] != null)
    {
        <div style="background:#1f1f1f; border-left:4px solid #D4AF37; padding:14px; border-radius:8px; margin-bottom:20px;">
            <p style="color:#ddd; margin:0;">
                @TempData["MensajeCarrito"]
            </p>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:25px;">
            <h3 style="color:#D4AF37;">Tu carrito está vacío</h3>

            <p style="color:#ccc;">
                Todavía no agregaste películas o series para comprar o alquilar.
            </p>

            <a href="@Url.Action("Index", "Pelicula")"
               style="display:inline-block; margin-top:10px; background:#D4AF37; color:#111; padding:10px 18px; border-radius:8px; text-decoration:none; font-weight:bold;">
                Ver películas
            </a>
        </div>
    }
    else
    {
        <div style="background:#151515; border:1px solid #333; border-radius:14px; overflow:hidden;">

            <table class="table" style="color:white; margin:0;">
                <thead style="background:#202020;">
                    <tr>
                        <th style="color:#D4AF37; padding:15px;">Título</th>
                        <th style="color:#D4AF37; padding:15px;">Tipo</th>
                        <th style="color:#D4AF37; padding:15px;">Operación</th>
                        <th style="color:#D4AF37; padding:15px;">Moneda</th>
                        <th style="color:#D4AF37; padding:15px;">Precio</th>
                        <th style="color:#D4AF37; padding:15px;">Cantidad</th>
                        <th style="color:#D4AF37; padding:15px;">Total</th>
                        <th style="color:#D4AF37; padding:15px;">Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-top:1px solid #333;">
                            <td style="padding:15px;">
                                @item.Titulo
                            </td>

                            <td style="padding:15px;">
                                @item.TipoContenido
                            </td>

                            <td style="padding:15px;">
                                @item.TipoOperacion
                            </td>

                            <td style="padding:15px;">
                                @item.Moneda
                            </td>

                            <td style="padding:15px;">
                                @if (item.TienePromocion)
                                {
                                    <span style="color:#888; text-decoration:line-through; display:block;">
                                        @item.Moneda @item.PrecioOriginal.ToString("0.00")
                                    </span>
                                    <span style="color:#D4AF37; font-weight:bold;">
                                        @item.Moneda @item.Precio.ToString("0.00")
                                    </span>
                                    <small style="display:block; color:#9fdf9f;">
                                        @item.NombrePromocion - @item.PorcentajeDescuento.ToString("0.##")% OFF
                                    </small>
                                }
                                else
                                {
                                    <span>@item.Moneda @item.Precio.ToString("0.00")</span>
                                }
                            </td>

                            <td style="padding:15px;">
                                @item.Cantidad
                            </td>

                            <td style="padding:15px; color:#D4AF37; font-weight:bold;">
                                @if (item.TienePromocion)
                                {
                                    <span style="color:#888; text-decoration:line-through; display:block; font-weight:normal;">
                                        @item.Moneda @item.TotalOriginal.ToString("0.00")
                                    </span>
                                }
                                @item.Moneda @item.Total.ToString("0.00")
                            </td>
                            <td style="padding:15px;">
                                @using (Html.BeginForm("Eliminar", "Carrito", FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="idCarritoItem" value="@item.IdCarritoItem" />

                                    <button type="submit"
                                            onclick="return confirm('¿Seguro que querés eliminar este item del carrito?');"
                                            style="background:#8b1e1e; color:white; border:none; border-radius:8px; padding:8px 12px;">
                                        Eliminar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

        <div class="row mt-4">

            <div class="col-md-8">
                <div style="background:#151515; border:1px solid #333; border-radius:14px; padding:22px;">
                    <h4 style="color:#D4AF37; margin-bottom:12px;">
                        Resumen
                    </h4>

                    <p style="color:#ccc; margin-bottom:8px;">
                        Cantidad de items: @Model.Sum(x => x.Cantidad)
                    </p>

                    <p style="color:#aaa; margin:0;">
                        Los precios fueron agregados según la moneda seleccionada, la cotización actual y las promociones por clima activas.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div style="background:#151515; border:1px solid #D4AF37; border-radius:14px; padding:22px;">

                    <h4 style="color:#D4AF37; margin-bottom:15px;">
                        Totales por moneda
                    </h4>

                    @foreach (var grupo in Model.GroupBy(x => x.Moneda))
                    {
                        <p style="color:white; font-size:18px; margin-bottom:8px;">
                            <strong>@grupo.Key:</strong>
                            @grupo.Sum(x => x.Total).ToString("0.00")
                        </p>
                    }

                    <button type="button"
                            style="width:100%; background:#D4AF37; color:#111; border:none; border-radius:8px; padding:12px; font-weight:bold; margin-top:15px;">
                        Finalizar compra
                    </button>

                </div>
            </div>

        </div>
    }

</div>
