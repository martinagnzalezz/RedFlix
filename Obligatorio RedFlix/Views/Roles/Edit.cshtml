@model Obligatorio_RedFlix.Models.Role
@{
    ViewBag.Title = "Editar Rol";
}

@section styles {
    <style>
        .admin-form-page {
            display: flex;
            justify-content: center;
            padding: 40px 20px;
        }

        .admin-form-box {
            background: #111;
            border: 1px solid #2a2a2a;
            border-radius: 12px;
            padding: 36px 40px;
            width: 100%;
            max-width: 460px;
        }

            .admin-form-box h2 {
                color: #F0F0F0;
                font-weight: 700;
                margin-bottom: 24px;
                font-size: 22px;
            }

        .rf-input-group {
            margin-bottom: 18px;
        }

            .rf-input-group label {
                display: block;
                font-size: 12px;
                color: #888;
                margin-bottom: 6px;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .rf-input-group input {
                width: 100%;
                background: #1a1a1a;
                border: 1px solid #2a2a2a;
                border-radius: 8px;
                padding: 12px 14px;
                color: #F0F0F0;
                font-size: 15px;
                outline: none;
                transition: border 0.2s;
            }

                .rf-input-group input:focus {
                    border-color: #D4A017;
                }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .btn-gold {
            background: #D4A017;
            color: #000;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
        }

            .btn-gold:hover {
                background: #F0C040;
            }

        .btn-outline-gray {
            background: transparent;
            color: #ccc;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 12px 22px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
        }

            .btn-outline-gray:hover {
                border-color: #555;
                color: #fff;
                text-decoration: none;
            }

        .text-danger {
            color: #e50914 !important;
            font-size: 13px;
        }
    </style>
}

<div class="admin-form-page">
    <div class="admin-form-box">
        <h2>Editar rol</h2>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.IdRol)
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="rf-input-group">
                @Html.LabelFor(model => model.Nombre)
                @Html.TextBoxFor(model => model.Nombre)
                @Html.ValidationMessageFor(model => model.Nombre)
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-gold">Guardar cambios</button>
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-outline-gray" })
            </div>
        }
    </div>
</div>